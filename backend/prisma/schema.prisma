generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Group {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("gold")
  teams     Team[]
  matches   Match[]  @relation("MatchGroup")
  createdAt DateTime @default(now())
  @@map("groups")
}

model Team {
  id          String        @id @default(cuid())
  name        String
  emoji       String        @default("🏏")
  captain     String        @default("")
  group       Group?        @relation(fields: [groupId], references: [id], onDelete: SetNull)
  groupId     String?
  squad       SquadMember[]
  players     Player[]
  matchesT1   Match[]       @relation("MatchTeam1")
  matchesT2   Match[]       @relation("MatchTeam2")
  sentiments  Sentiment[]
  createdAt   DateTime      @default(now())
  @@map("teams")
}

model SquadMember {
  id        String   @id @default(cuid())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId    String
  name      String
  role      String   @default("bat")
  createdAt DateTime @default(now())
  @@map("squad_members")
}

model Match {
  id         String      @id @default(cuid())
  stage      String      @default("group")
  group      Group?      @relation("MatchGroup", fields: [groupId], references: [id], onDelete: SetNull)
  groupId    String?
  matchNo    String      @default("")
  team1      Team        @relation("MatchTeam1", fields: [team1Id], references: [id])
  team1Id    String
  team2      Team        @relation("MatchTeam2", fields: [team2Id], references: [id])
  team2Id    String
  date       String      @default("")
  time       String      @default("")
  year       Int         @default(2026)
  venue      String      @default("Pattan Cricket Ground")
  status     String      @default("upcoming")
  result     String      @default("")
  score1     String      @default("")
  score2     String      @default("")
  overs      Int         @default(10)
  highlights Json        @default("{}")
  innings1   Json        @default("{}")
  ballEvents BallEvent[]
  sentiments Sentiment[]
  createdAt  DateTime    @default(now())
  @@index([status])
  @@map("matches")
}

model Player {
  id          String   @id @default(cuid())
  name        String
  emoji       String   @default("🏏")
  team        Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  teamId      String?
  role        String   @default("batting")
  runs        Int      @default(0)
  wickets     Int      @default(0)
  strikeRate  Float    @default(0)
  economy     Float    @default(0)
  best        String   @default("")
  createdAt   DateTime @default(now())
  @@index([teamId])
  @@map("players")
}

model BallEvent {
  id         String   @id @default(cuid())
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId    String
  innings    Int      @default(1)
  over       Int      @default(0)
  ball       Int      @default(0)
  runs       Int      @default(0)
  isWicket   Boolean  @default(false)
  isWide     Boolean  @default(false)
  isNoBall   Boolean  @default(false)
  isBye      Boolean  @default(false)
  batsman    String   @default("")
  bowler     String   @default("")
  commentary String   @default("")
  createdAt  DateTime @default(now())
  @@index([matchId])
  @@map("ball_events")
}

model Sentiment {
  id        String   @id @default(cuid())
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId   String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId    String
  sessionId String
  createdAt DateTime @default(now())
  @@unique([matchId, sessionId])
  @@index([matchId])
  @@map("sentiments")
}

model Ad {
  id        String   @id @default(cuid())
  content   String
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  @@map("ads")
}

model Poll {
  id        String   @id @default(cuid())
  type      String   @default("Poll")
  question  String
  options   Json     @default("[]")
  votes     Json     @default("[]")
  votedBy   Json     @default("{}")
  createdAt DateTime @default(now())
  @@map("polls")
}

model Org {
  id        String   @id @default(cuid())
  name      String
  role      String   @default("")
  emoji     String   @default("🏢")
  since     String   @default("")
  createdAt DateTime @default(now())
  @@map("orgs")
}

model Rule {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  @@map("rules")
}

model Announcement {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  @@map("announcements")
}

model Gallery {
  id        String   @id @default(cuid())
  emoji     String   @default("🖼️")
  label     String   @default("")
  category  String   @default("match")
  createdAt DateTime @default(now())
  @@map("gallery")
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  @@map("push_subscriptions")
}

model LiveState {
  id        Int      @id @default(1)
  data      Json?
  updatedAt DateTime @updatedAt
  @@map("live_state")
}
